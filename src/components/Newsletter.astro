---
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---
<section id="newsletter" class:list={["scroll-mt-24", cls]}>
  <div class="container">
    <div class="card reveal relative mx-auto max-w-4xl overflow-hidden bg-gradient-to-br from-brand-700 via-brand-800 to-brand-900 text-white">
      <div class="pointer-events-none absolute inset-0 arabesque text-white/[0.05]"></div>
      <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-gold-400/20 blur-3xl"></div>
      <div class="relative grid items-center gap-8 p-8 md:grid-cols-2 md:p-12">
        <div>
          <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold backdrop-blur">
            <Icon name="mail" class="h-4 w-4 text-gold-300" /> النشرة البريدية
          </span>
          <h2 class="text-2xl font-extrabold leading-tight md:text-3xl">
            كن أول من يعرف <span class="grad-text">أحكام الزكاة</span>
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-brand-50/90">
            اشترك مجانًا لتصلك أهم المقالات الفقهية، وتذكيرات مواقيت الزكاة،
            وتحديثات الحاسبة. بريدك آمن ولن نرسل لك رسائل مزعجة.
          </p>
          <ul class="mt-5 space-y-2 text-sm text-brand-50/85">
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-gold-300" /> مقالات فقهية موثّقة أسبوعيًا</li>
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-gold-300" /> تذكير بموعد إخراج الزكاة</li>
            <li class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-gold-300" /> إلغاء الاشتراك في أي وقت</li>
          </ul>
        </div>

        <div>
          <!-- Netlify Forms: يعمل تلقائيًا عند النشر على Netlify دون أي خادم خلفي -->
          <form
            name="newsletter"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/?subscribed=1#newsletter"
            class="cz-newsletter-form rounded-2xl bg-white/10 p-5 backdrop-blur"
          >
            <input type="hidden" name="form-name" value="newsletter" />
            <p class="hidden">
              <label>لا تملأ هذا الحقل: <input name="bot-field" /></label>
            </p>
            <label for="nl-name" class="mb-1 block text-xs font-semibold text-brand-50/80">الاسم (اختياري)</label>
            <input
              id="nl-name"
              type="text"
              name="name"
              autocomplete="name"
              placeholder="اسمك الكريم"
              class="mb-3 w-full rounded-xl border border-white/20 bg-white/10 px-4 py-2.5 text-sm text-white placeholder:text-white/50 focus:border-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-300/40"
            />
            <label for="nl-email" class="mb-1 block text-xs font-semibold text-brand-50/80">البريد الإلكتروني</label>
            <input
              id="nl-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              placeholder="example@email.com"
              dir="ltr"
              class="mb-4 w-full rounded-xl border border-white/20 bg-white/10 px-4 py-2.5 text-sm text-white placeholder:text-white/50 focus:border-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-300/40"
            />
            <button type="submit" class="btn-gold w-full justify-center text-base">
              <Icon name="mail" class="h-5 w-5" /> اشترك الآن مجانًا
            </button>
            <p id="nl-success" class="mt-3 hidden rounded-xl bg-gold-300/20 px-4 py-2.5 text-center text-sm font-semibold text-gold-100">
              ✓ تم اشتراكك بنجاح — شكرًا لك! سيصلك كل جديد.
            </p>
          </form>
          <p class="mt-3 text-center text-xs text-brand-50/60">
            نحترم خصوصيتك — <a href="/privacy" class="underline hover:text-white">سياسة الخصوصية</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // إظهار رسالة النجاح عند العودة بعد الإرسال (?subscribed=1)
  const params = new URLSearchParams(window.location.search);
  if (params.get("subscribed") === "1") {
    const ok = document.getElementById("nl-success");
    ok?.classList.remove("hidden");
    document.getElementById("newsletter")?.scrollIntoView({ behavior: "smooth", block: "center" });
    // تتبّع الحدث إن كان GA مفعّلًا
    (window as unknown as { czTrack?: (n: string) => void }).czTrack?.("newsletter_subscribe");
  }
</script>
