---
import Icon from "./Icon.astro";
import AdSlot from "./AdSlot.astro";
import { ZAKAT_TABS } from "@data/zakatTypes";
import {
  STATS, ABOUT_CARDS, FEATURES, TIPS, COMPARE_ROWS,
  COMPETITOR_STRENGTHS, COMPETITOR_GAPS, FAQS,
} from "@data/content";
import { SITE, SOCIAL_SHARE } from "@lib/site";
---
<!-- STATS -->
<section class="container py-14">
  <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
    {STATS.map((s) => (
      <div class="card card-hover reveal p-6 text-center">
        <div class="mx-auto mb-3 grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600 dark:bg-slate-800 dark:text-brand-300"><Icon name={s.icon} class="h-6 w-6" /></div>
        <div class="text-3xl font-extrabold text-brand-700 dark:text-brand-300">{s.value}</div>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{s.label}</p>
      </div>
    ))}
  </div>
</section>

<AdSlot label="مساحة إعلانية — أعلى الأدوات" />

<!-- TOOLS -->
<section id="tools" class="scroll-mt-24 bg-slate-50/70 py-16 dark:bg-slate-900/40 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center reveal">
      <span class="eyebrow"><Icon name="layers" class="h-4 w-4" /> أدوات الحاسبة</span>
      <h2 class="h-section">كل أنواع الزكاة في مكان واحد</h2>
      <p class="h-sub">اختر الأداة المناسبة لتنتقل مباشرةً إلى حسابها في الحاسبة الذكية.</p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {ZAKAT_TABS.map((t) => (
        <a href="#calculator" class="card card-hover reveal group p-6" data-jump={t.id}>
          <div class="mb-4 grid h-14 w-14 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-white shadow-glow transition-transform group-hover:scale-110"><Icon name={t.icon} class="h-7 w-7" /></div>
          <h3 class="mb-1.5 text-lg font-bold text-slate-900 dark:text-white">{t.label}</h3>
          <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">{t.short}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about" class="container scroll-mt-24 py-16 md:py-24">
  <div class="mx-auto mb-12 max-w-2xl text-center reveal">
    <span class="eyebrow"><Icon name="book" class="h-4 w-4" /> تعرّف على الزكاة</span>
    <h2 class="h-section">فقه الزكاة بأسلوب مبسّط</h2>
    <p class="h-sub">كل ما تحتاج معرفته عن الزكاة وأحكامها ومصارفها بلغة سهلة وموثّقة.</p>
  </div>
  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {ABOUT_CARDS.map((c) => (
      <div class="card reveal p-6">
        <div class="mb-4 grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-slate-800 dark:text-brand-300"><Icon name={c.icon} class="h-6 w-6" /></div>
        <h3 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">{c.title}</h3>
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">{c.text}</p>
      </div>
    ))}
  </div>
</section>

<!-- COMPARE -->
<section class="bg-slate-50/70 py-16 dark:bg-slate-900/40 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center reveal">
      <span class="eyebrow"><Icon name="scale" class="h-4 w-4" /> لماذا CalcuZakat؟</span>
      <h2 class="h-section">قارن بنفسك</h2>
      <p class="h-sub">مقارنة صريحة بين ما نقدّمه وبين الحاسبات التقليدية.</p>
    </div>
    <div class="card reveal mx-auto max-w-3xl overflow-hidden">
      <table class="w-full text-right">
        <thead>
          <tr class="bg-brand-700 text-white">
            <th class="p-4 text-sm font-bold">الميزة</th>
            <th class="p-4 text-center text-sm font-bold">CalcuZakat</th>
            <th class="p-4 text-center text-sm font-bold">حاسبات أخرى</th>
          </tr>
        </thead>
        <tbody>
          {COMPARE_ROWS.map((r) => (
            <tr class="border-b border-slate-100 transition last:border-0 hover:bg-brand-50/50 dark:border-slate-800 dark:hover:bg-slate-800/50">
              <td class="p-4 text-sm font-semibold text-slate-700 dark:text-slate-200">{r.feature}</td>
              <td class="p-4 text-center">{r.us ? <Icon name="check" class="mx-auto h-5 w-5 text-brand-600" /> : <Icon name="x" class="mx-auto h-5 w-5 text-slate-300" />}</td>
              <td class="p-4 text-center">{r.others ? <Icon name="check" class="mx-auto h-5 w-5 text-brand-600" /> : <Icon name="x" class="mx-auto h-5 w-5 text-slate-300" />}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- COMPETITORS -->
<section class="container py-16 md:py-24">
  <div class="mx-auto mb-12 max-w-2xl text-center reveal">
    <span class="eyebrow"><Icon name="target" class="h-4 w-4" /> تحليل المنافسين</span>
    <h2 class="h-section">تعلّمنا من الأفضل وتجاوزنا الباقي</h2>
    <p class="h-sub">درسنا أشهر حاسبات الزكاة عالميًا، فأخذنا مميزاتها وعالجنا عيوبها.</p>
  </div>
  <div class="grid gap-6 md:grid-cols-2">
    <div class="card reveal p-7">
      <h3 class="mb-5 flex items-center gap-2 text-lg font-bold text-brand-700 dark:text-brand-300"><Icon name="check" class="h-5 w-5" /> مميزات تبنّيناها</h3>
      <div class="space-y-4">
        {COMPETITOR_STRENGTHS.map((p) => (
          <div class="flex gap-3">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-slate-800 dark:text-brand-300"><Icon name={p.icon} class="h-5 w-5" /></div>
            <div><h4 class="font-bold text-slate-800 dark:text-white">{p.title}</h4><p class="text-sm text-slate-500 dark:text-slate-400">{p.text}</p></div>
          </div>
        ))}
      </div>
    </div>
    <div class="card reveal p-7">
      <h3 class="mb-5 flex items-center gap-2 text-lg font-bold text-gold-600 dark:text-gold-400"><Icon name="zap" class="h-5 w-5" /> عيوب عالجناها</h3>
      <div class="space-y-4">
        {COMPETITOR_GAPS.map((p) => (
          <div class="flex gap-3">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-gold-50 text-gold-600 dark:bg-slate-800 dark:text-gold-400"><Icon name={p.icon} class="h-5 w-5" /></div>
            <div><h4 class="font-bold text-slate-800 dark:text-white">{p.title}</h4><p class="text-sm text-slate-500 dark:text-slate-400">{p.text}</p></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<AdSlot label="مساحة إعلانية — وسط الصفحة" />

<!-- FEATURES -->
<section class="bg-slate-50/70 py-16 dark:bg-slate-900/40 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center reveal">
      <span class="eyebrow"><Icon name="sparkles" class="h-4 w-4" /> المميزات</span>
      <h2 class="h-section">مصمّمة لتكون الأفضل</h2>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f) => (
        <div class="card reveal p-6">
          <div class="mb-4 grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br from-gold-300 to-gold-500 text-brand-950"><Icon name={f.icon} class="h-6 w-6" /></div>
          <h3 class="mb-1.5 text-lg font-bold text-slate-900 dark:text-white">{f.title}</h3>
          <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TIPS -->
<section class="container py-16 md:py-24">
  <div class="mx-auto mb-12 max-w-2xl text-center reveal">
    <span class="eyebrow"><Icon name="star" class="h-4 w-4" /> نصائح عملية</span>
    <h2 class="h-section">أخرج زكاتك بثقة</h2>
  </div>
  <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-2">
    {TIPS.map((t) => (
      <div class="reveal flex gap-4 rounded-2xl bg-white p-5 shadow-soft dark:bg-slate-900">
        <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-slate-800 dark:text-brand-300"><Icon name={t.icon} class="h-5 w-5" /></div>
        <div><h3 class="font-bold text-slate-800 dark:text-white">{t.title}</h3><p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{t.text}</p></div>
      </div>
    ))}
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="scroll-mt-24 bg-slate-50/70 py-16 dark:bg-slate-900/40 md:py-24">
  <div class="container mx-auto max-w-3xl">
    <div class="mb-12 text-center reveal">
      <span class="eyebrow"><Icon name="info" class="h-4 w-4" /> الأسئلة الشائعة</span>
      <h2 class="h-section">إجابات لأكثر الأسئلة تكرارًا</h2>
    </div>
    <div class="space-y-3">
      {FAQS.map((f) => (
        <details class="cz-faq card reveal overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-3 p-5 font-bold text-slate-800 dark:text-white">
            <span>{f.q}</span>
            <span class="cz-faq-icon shrink-0 text-brand-600 transition-transform"><Icon name="chevron" class="h-5 w-5" /></span>
          </summary>
          <div class="border-t border-slate-100 p-5 text-sm leading-relaxed text-slate-600 dark:border-slate-800 dark:text-slate-300">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="container scroll-mt-24 py-16 md:py-24">
  <div class="card reveal mx-auto max-w-4xl overflow-hidden">
    <div class="grid md:grid-cols-2">
      <div class="bg-gradient-to-br from-brand-700 to-brand-900 p-8 text-white md:p-10">
        <h2 class="text-2xl font-extrabold">تواصل معنا</h2>
        <p class="mt-3 text-brand-50/90">هل لديك سؤال أو اقتراح لتحسين الحاسبة؟ يسعدنا تواصلك.</p>
        <a href={`mailto:${SITE.email}`} class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white/10 px-4 py-3 font-semibold transition hover:bg-white/20"><Icon name="mail" class="h-5 w-5" /> {SITE.email}</a>
      </div>
      <div class="p-8 md:p-10">
        <h3 class="mb-4 text-lg font-bold text-slate-900 dark:text-white">شارك الحاسبة</h3>
        <p class="mb-5 text-sm text-slate-500 dark:text-slate-400">ساعد غيرك على حساب زكاته بدقة — الدال على الخير كفاعله.</p>
        <div class="flex flex-wrap gap-3">
          <a href={SOCIAL_SHARE.whatsapp} target="_blank" rel="noopener" class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition hover:bg-brand-100 dark:bg-slate-800 dark:text-brand-300"><Icon name="whatsapp" class="h-6 w-6" /></a>
          <a href={SOCIAL_SHARE.twitter} target="_blank" rel="noopener" class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition hover:bg-brand-100 dark:bg-slate-800 dark:text-brand-300"><Icon name="twitter" class="h-6 w-6" /></a>
          <a href={SOCIAL_SHARE.facebook} target="_blank" rel="noopener" class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition hover:bg-brand-100 dark:bg-slate-800 dark:text-brand-300"><Icon name="facebook" class="h-6 w-6" /></a>
          <a href={SOCIAL_SHARE.telegram} target="_blank" rel="noopener" class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition hover:bg-brand-100 dark:bg-slate-800 dark:text-brand-300"><Icon name="telegram" class="h-6 w-6" /></a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // FAQ chevron rotate + jump-to-tab from tool cards
  document.querySelectorAll<HTMLDetailsElement>(".cz-faq").forEach((d) => {
    d.addEventListener("toggle", () => {
      d.querySelector(".cz-faq-icon")?.classList.toggle("rotate-180", d.open);
    });
  });
  document.querySelectorAll<HTMLElement>("[data-jump]").forEach((a) => {
    a.addEventListener("click", () => {
      const id = a.dataset.jump;
      const btn = document.querySelector<HTMLElement>(`[data-tab="${id}"]`);
      setTimeout(() => btn?.click(), 300);
    });
  });
</script>
