---
import BaseLayout from "@layouts/BaseLayout.astro";
import Icon from "@components/Icon.astro";
---
<BaseLayout title="الصفحة غير موجودة | CalcuZakat" description="الصفحة المطلوبة غير موجودة." path="/404" noindex>
  <section class="container flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <div class="grad-text text-8xl font-extrabold md:text-9xl">404</div>
    <h1 class="mt-4 text-2xl font-extrabold text-slate-900 dark:text-white md:text-3xl">الصفحة غير موجودة</h1>
    <p class="mt-3 max-w-md text-slate-500 dark:text-slate-400">
      عذرًا، الصفحة التي تبحث عنها غير موجودة أو تم نقلها.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary"><Icon name="arrowUp" class="h-5 w-5" /> العودة للرئيسية</a>
      <a href="/#calculator" class="btn-outline"><Icon name="calculator" class="h-5 w-5" /> احسب زكاتك</a>
    </div>
  </section>
</BaseLayout>
